  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Inverter Power — raw vs filtered",
      "description": "raw is every poll (requires logger --raw). filtered is what the deadband decided to keep.",
      "gridPos": { "x": 0, "y": 0, "h": 9, "w": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb-fern" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "unit": "watt"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "filtered" },
            "properties": [
              { "id": "custom.lineInterpolation", "value": "stepAfter" },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.pointSize", "value": 6 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "displayName", "value": "filtered" }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "raw" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "displayName", "value": "raw" }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "raw",
          "datasource": { "type": "influxdb", "uid": "influxdb-fern" },
          "query": "from(bucket: \"home\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"power_raw\" and r[\"_field\"] == \"inverter_power\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean)"
        },
        {
          "refId": "filtered",
          "datasource": { "type": "influxdb", "uid": "influxdb-fern" },
          "query": "from(bucket: \"home\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"power\" and r[\"_field\"] == \"inverter_power\")"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
